FROM node:20-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci

FROM node:20-alpine AS builder
WORKDIR /app
ARG NEXT_PUBLIC_API_BASE_URL
ARG NEXT_PUBLIC_API_AUTH_TOKEN
ARG NEXT_PUBLIC_CHAIN_ID
ARG NEXT_PUBLIC_RPC_URL
ARG NEXT_PUBLIC_CONTRACT_CONFIDENTIAL_RWA_TOKEN
ARG NEXT_PUBLIC_CONTRACT_DISCLOSURE_REGISTRY
ARG NEXT_PUBLIC_CONTRACT_TRANSFER_CONTROLLER
ARG NEXT_PUBLIC_CONTRACT_AUDIT_ANCHOR
ARG NEXT_PUBLIC_CONTRACT_TENANT_FACTORY
ARG NEXT_PUBLIC_CONTRACT_SETTLEMENT_ASSET
ARG NEXT_PUBLIC_CONTRACT_SETTLEMENT_VAULT
ENV NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL
ENV NEXT_PUBLIC_API_AUTH_TOKEN=$NEXT_PUBLIC_API_AUTH_TOKEN
ENV NEXT_PUBLIC_CHAIN_ID=$NEXT_PUBLIC_CHAIN_ID
ENV NEXT_PUBLIC_RPC_URL=$NEXT_PUBLIC_RPC_URL
ENV NEXT_PUBLIC_CONTRACT_CONFIDENTIAL_RWA_TOKEN=$NEXT_PUBLIC_CONTRACT_CONFIDENTIAL_RWA_TOKEN
ENV NEXT_PUBLIC_CONTRACT_DISCLOSURE_REGISTRY=$NEXT_PUBLIC_CONTRACT_DISCLOSURE_REGISTRY
ENV NEXT_PUBLIC_CONTRACT_TRANSFER_CONTROLLER=$NEXT_PUBLIC_CONTRACT_TRANSFER_CONTROLLER
ENV NEXT_PUBLIC_CONTRACT_AUDIT_ANCHOR=$NEXT_PUBLIC_CONTRACT_AUDIT_ANCHOR
ENV NEXT_PUBLIC_CONTRACT_TENANT_FACTORY=$NEXT_PUBLIC_CONTRACT_TENANT_FACTORY
ENV NEXT_PUBLIC_CONTRACT_SETTLEMENT_ASSET=$NEXT_PUBLIC_CONTRACT_SETTLEMENT_ASSET
ENV NEXT_PUBLIC_CONTRACT_SETTLEMENT_VAULT=$NEXT_PUBLIC_CONTRACT_SETTLEMENT_VAULT
COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN npm run build

FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3313
ENV HOSTNAME=0.0.0.0
COPY --from=builder /app/public ./public
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
EXPOSE 3313
CMD ["node", "server.js"]
